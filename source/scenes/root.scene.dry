Q.jons_leader = "Onesimo Redondo";

// presidential activity
Q.alcala_zamora_relation = 70;
// whether or not Alcala Zamora can dismiss the government.
Q.alcala_zamora_enabled = 0;

// The array of forces - paramilitary groups
// Number of members in 1931 (in thousands) PLACEHOLDER BUSCAR CIRFAS
// Ejercito, Guardia Civil, Guardia de Asalto, Juventudes Socialistas, Milicias Comunistas, Milicias Anarquistas, Milicias Falangistas
Q.js_strength = 50;
Q.js_militancy = 0.01;
Q.js_banned = 0;
Q.mc_strength = 10;
Q.mc_militancy = 0.5;
Q.mc_banned = 0;
Q.ma_strength = 150;
