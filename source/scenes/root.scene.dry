@start
on-arrival: {!
Q.started = 1;
// time elapsed (in months)
Q.time = 1;
Q.year = 1931;
Q.month = 7;
// how many actions have been taken this month?
Q.month_actions = 0;

// 0 = normal difficulty, 1 = hard mode, 2 = hard mode no saves
Q.difficulty = 0;
Q.historical_mode = 0;
// old demographics
Q.old_demographics = 0;
// use decimals for reichstag seats
// TODO: not yet implemented
Q.use_decimals = 0;

// party resources
Q.resources = 2;
// party dues
Q.dues = 2; // preguntar que es

// ugt resources
Q.ugt_resources = 2;
// ugt dues
Q.ugt_dues = 2;

// the state of the party
// overall dissent reduces every increase in party support.
Q.dissent = 0.05;
Q.dissent_percent = 5;

// factions
Q.factions = ['caballeristas', 'prietistas', 'besteiristas'];
// should this be normalized to 100%?
Q.caballeristas_strength = 30;
Q.caballeristas_dissent = 20;
Q.prietistas_strength = 45;
Q.prietistas_dissent = 0;
Q.besteiristas_strength = 25;
Q.besteiristas_dissent = 5;

// secret events...
Q.besteiristas_split = 0;
Q.caballeristas_split = 0;
Q.prietistas_resigned = 0;

// agrarian_reform_urgency indicates how seriously the PSOE is taking the agrarian question - scale from 0 to 10.
Q.agrarian_reform_urgency = 0;
// falange_urgency indicates how seriously the PSOE takes the falange - scale from 0 to 10.
Q.falange_urgency = 0;
// radicalization indicates how radical the PSOE's rhetoric is - scale from 0 to 10.
Q.radicalization = 0;
// Support for democratic reform within the PSOE relative to 1931
Q.democratization = 0;
// Support for a communist coalition relative to 1931
Q.communist_coalition = 0;

// inter-party relations
// republicans
Q.ar_relation = 70; //accion republicana
Q.prrs_relation = 65; //partido republicano radical socialista
Q.other_left_republicans_relation = 55;
Q.prr_relation = 40; //partido republicano radical
Q.dlr_relation = 50; //derecha liberal republicana
